{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/branch-guard.js",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/overwrite-guard.js",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/skill-auto-commit.js"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/session-sync-tool.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/worktree-data-link.js"
          },
          {
            "type": "command",
            "command": "bash scripts/base-return-to-main.sh 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/worktree-state-surface.js"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/gsd-check-update.js"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/session-sync.js"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/load-memory-snapshot.js"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/epitaxy-stash-guard.js"
          },
          {
            "type": "command",
            "command": "bash scripts/backup-memory.sh >/dev/null 2>&1 || true",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/session-sync-prompt.js"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/session-memory-block.js"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/session-title-hint.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .codex/hooks/session-sync-stop.js"
          },
          {
            "type": "command",
            "command": "node .codex/hooks/footer-presence-check.js"
          }
        ]
      }
    ]
  }
}
