{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/aios-authority-guard.js",
            "timeout": 5
          }
        ],
        "matcher": "Write|Edit|MultiEdit|Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/gsd-prompt-guard.js",
            "timeout": 5
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/branch-guard.js",
            "timeout": 5
          }
        ],
        "matcher": "Write|Edit|Bash"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/overwrite-guard.js",
            "timeout": 5
          }
        ],
        "matcher": "Write"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/gsd-context-monitor.js",
            "timeout": 10
          }
        ],
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/skill-auto-commit.js"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/session-sync-tool.js"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/worktree-data-link.js"
          },
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh scripts/base-return-to-main.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/worktree-state-surface.js"
          },
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/gsd-check-update.js"
          },
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/session-sync.js"
          },
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/load-memory-snapshot.js"
          },
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/epitaxy-stash-guard.js"
          },
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh scripts/backup-memory.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/session-sync-prompt.js"
          },
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/session-memory-block.js"
          },
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/session-title-hint.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/session-sync-stop.js"
          },
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/footer-presence-check.js"
          },
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh scripts/base-autosave.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/codex-hook.sh .claude/hooks/session-sync-notify.js"
          }
        ]
      }
    ]
  }
}
