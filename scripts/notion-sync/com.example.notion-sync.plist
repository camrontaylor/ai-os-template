<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Template launchd job for the optional Notion sync (macOS).
  Before loading it: copy this file to ~/Library/LaunchAgents/ and replace every
  /ABSOLUTE/PATH/TO/ai-os below with the real absolute path to your AI-OS repo.
  See README.md in this folder for the full setup. Runs daily at 22:30 local time.
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.example.notion-sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/ABSOLUTE/PATH/TO/ai-os/scripts/notion-sync/run-notion-sync.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/ABSOLUTE/PATH/TO/ai-os</string>

  <key>StandardOutPath</key>
  <string>/ABSOLUTE/PATH/TO/ai-os/context/notion/sync.log</string>

  <key>StandardErrorPath</key>
  <string>/ABSOLUTE/PATH/TO/ai-os/context/notion/sync.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>22</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>
</dict>
</plist>
